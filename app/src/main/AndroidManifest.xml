<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permiso para acceso a internet -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Permiso para verificar estado de red -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Permiso para notificaciones en Android 13 o superior -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Permiso para usar la cámara -->
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.MiPrimeraApp">

        <!-- Aquí configuro la API KEY de Google Maps -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyCf9bZ8hWrWtX8t_YfJeTYLHge4YRNFUvM" />

        <!-- Provider para compartir archivos PDF -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">

            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Receiver para recordatorios exactos de vacunas -->
        <receiver
            android:name=".VaccineReminderReceiver"
            android:exported="false" />

        <receiver
            android:name=".CitaReminderReceiver"
            android:exported="false" />

        <!-- Activities de la aplicación -->
        <activity
            android:name=".OwnerProfileActivity"
            android:exported="false" />

        <activity
            android:name=".AddCitaActivity"
            android:exported="false" />

        <activity
            android:name=".CitasListActivity"
            android:exported="false" />

        <activity
            android:name=".BusquedaActivity"
            android:exported="false" />

        <activity
            android:name=".SharePetInfoActivity"
            android:exported="false" />

        <activity
            android:name=".NotificationsActivity"
            android:exported="false" />

        <activity
            android:name=".OrdersHistoryActivity"
            android:exported="false" />

        <activity
            android:name=".CheckoutActivity"
            android:exported="false" />

        <activity
            android:name=".CartActivity"
            android:exported="false" />

        <activity
            android:name=".StoreActivity"
            android:exported="false" />

        <activity
            android:name=".HistorialDetailActivity"
            android:exported="false" />

        <activity
            android:name=".HistorialListActivity"
            android:exported="false" />

        <activity
            android:name=".VacunasListActivity"
            android:exported="false" />

        <activity
            android:name=".AddHistorialActivity"
            android:exported="false" />

        <activity
            android:name=".AddVacunacionActivity"
            android:exported="false" />

        <activity
            android:name=".PetDetailActivity"
            android:exported="false" />

        <activity
            android:name=".PetsListActivity"
            android:exported="false" />

        <activity
            android:name=".AddPetActivity"
            android:exported="false" />

        <activity
            android:name=".RegisterActivity"
            android:exported="false" />

        <activity
            android:name=".HomeActivity"
            android:exported="false" />

        <activity
            android:name=".LoginActivity"
            android:exported="false" />

        <!-- Activity principal -->
        <activity
            android:name=".MainActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>
    </application>

</manifest>