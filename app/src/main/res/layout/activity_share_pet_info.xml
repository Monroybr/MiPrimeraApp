<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:padding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Título principal -->
        <TextView
            android:id="@+id/tvTituloShare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Compartir información en PDF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:textAlignment="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Texto de apoyo -->
        <TextView
            android:id="@+id/tvSubtituloShare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Selecciona los datos que deseas exportar y compartir de forma segura."
            android:textSize="14sp"
            android:textColor="#475569"
            android:textAlignment="center"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloShare"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Tarjeta principal de mascota -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardMascotaInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintTop_toBottomOf="@id/tvSubtituloShare"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvEtiquetaMascota"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mascota seleccionada"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#2563EB" />

                <TextView
                    android:id="@+id/tvNombreMascotaShare"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mascota"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvDescripcionPdf"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="El documento PDF incluirá la información clínica y/o el carnet de vacunación según la selección realizada."
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="10dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Tarjeta de selección -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardOpcionesPdf"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintTop_toBottomOf="@id/cardMascotaInfo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvSeleccionContenido"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selecciona el contenido"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A" />

                <CheckBox
                    android:id="@+id/cbVacunas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Incluir carnet de vacunación"
                    android:textSize="15sp"
                    android:textColor="#1E293B"
                    android:checked="true"
                    android:layout_marginTop="14dp" />

                <CheckBox
                    android:id="@+id/cbHistorial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Incluir historial médico"
                    android:textSize="15sp"
                    android:textColor="#1E293B"
                    android:checked="true"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Botón de acción -->
        <Button
            android:id="@+id/btnGenerarCompartirPdf"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Generar y compartir PDF"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="14dp"
            android:layout_marginTop="22dp"
            app:layout_constraintTop_toBottomOf="@id/cardOpcionesPdf"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Mensaje para errores o estado -->
        <TextView
            android:id="@+id/tvMensajeShare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#DC2626"
            android:textAlignment="center"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnGenerarCompartirPdf"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>