<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvTituloShare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Compartir información de la mascota"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvNombreMascotaShare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Mascota"
            android:textSize="18sp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloShare"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <CheckBox
            android:id="@+id/cbVacunas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Incluir carnet de vacunación"
            android:checked="true"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvNombreMascotaShare"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <CheckBox
            android:id="@+id/cbHistorial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Incluir historial médico"
            android:checked="true"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/cbVacunas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnGenerarCompartirPdf"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Generar y compartir PDF"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/cbHistorial"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvMensajeShare"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textAlignment="center"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/btnGenerarCompartirPdf"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>