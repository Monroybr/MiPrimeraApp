<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvFechaHist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha: dd/mm/aaaa"
            android:textStyle="bold"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/tvEnfermedadesHist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enfermedades: -"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvMedicacionHist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Medicación: -"
            android:layout_marginTop="6dp"/>

        <TextView
            android:id="@+id/tvProcedimientosHist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Procedimientos: -"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

</androidx.cardview.widget.CardView>