<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <RelativeLayout
            android:id="@+id/layoutHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:padding="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTituloHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hola 👋"
                    android:textSize="16sp"
                    android:textColor="#64748B" />

                <TextView
                    android:id="@+id/tvTituloPrincipalHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bienvenida a AppPet"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A" />
            </LinearLayout>

            <ImageView
                android:id="@+id/imgCampana"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_alignParentEnd="true"
                android:padding="7dp"
                android:scaleType="fitCenter"
                android:src="@drawable/campana"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Notificaciones" />

            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_alignEnd="@id/imgCampana"
                android:layout_marginEnd="-2dp"
                android:layout_marginTop="0dp"
                android:background="@android:color/holo_red_dark"
                android:text="0"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:gravity="center"
                android:visibility="gone" />

        </RelativeLayout>

        <TextView
            android:id="@+id/tvSubtitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Gestiona tus mascotas, vacunas, citas y productos desde un solo lugar."
            android:textSize="15sp"
            android:textColor="#475569"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/layoutHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPerfil"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="5dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👤 Perfil del dueño"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Consulta o actualiza tus datos personales."
                    android:textSize="13sp"
                    android:textColor="#64748B"
                    android:layout_marginTop="6dp" />

                <Button
                    android:id="@+id/btnMiPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mi perfil"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvMascotas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Mis mascotas"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#0F172A"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/cardPerfil"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardMascotas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="5dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintTop_toBottomOf="@id/tvMascotas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/layoutMascotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🐾 Mascotas registradas"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A" />

                <TextView
                    android:id="@+id/tvListaMascotas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aún no tienes mascotas registradas."
                    android:textSize="14sp"
                    android:textColor="#334155"
                    android:layout_marginTop="10dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp">

                    <Button
                        android:id="@+id/btnNuevaMascota"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Registrar"
                        android:textAllCaps="false"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnVerMascotas"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ver todas"
                        android:textAllCaps="false"
                        android:layout_marginStart="10dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvProductos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Servicios rápidos"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="#0F172A"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/cardMascotas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardServicios"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="5dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintTop_toBottomOf="@id/tvProductos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Accesos principales"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A" />

                <Button
                    android:id="@+id/btnProductos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🛒 Ver productos"
                    android:textAllCaps="false"
                    android:layout_marginTop="12dp" />

                <Button
                    android:id="@+id/btnBusqueda"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📍 Buscar veterinarias cercanas"
                    android:textAllCaps="false"
                    android:layout_marginTop="10dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>