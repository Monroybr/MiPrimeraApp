<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Contenedor principal de toda la pantalla -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- ================= HEADER ================= -->
        <!-- Aquí agrego el título de la app y la campana de notificaciones -->
        <RelativeLayout
            android:id="@+id/layoutHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Título principal -->
            <TextView
                android:id="@+id/tvTituloHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inicio"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#0F172A" />

            <!-- Campana de notificaciones personalizada -->
            <ImageView
                android:id="@+id/imgCampana"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:src="@drawable/campana"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Notificaciones" />

            <!-- Badge rojo para mostrar número de notificaciones -->
            <TextView
                android:id="@+id/tvBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_alignEnd="@id/imgCampana"
                android:layout_marginEnd="-4dp"
                android:layout_marginTop="-4dp"
                android:background="@android:color/holo_red_dark"
                android:text="0"
                android:textColor="@android:color/white"
                android:textSize="10sp"
                android:gravity="center"
                android:visibility="gone" />

        </RelativeLayout>

        <!-- ================= SUBTÍTULO ================= -->
        <TextView
            android:id="@+id/tvSubtitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Gestiona tus mascotas y compra productos"
            android:textSize="16sp"
            android:textColor="#475569"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/layoutHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ================= SECCIÓN MASCOTAS ================= -->
        <TextView
            android:id="@+id/tvMascotas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Mascotas registradas"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#0F172A"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Contenedor donde muestro las mascotas -->
        <LinearLayout
            android:id="@+id/layoutMascotas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:layout_marginTop="10dp"
            android:background="#FFFFFF"
            app:layout_constraintTop_toBottomOf="@id/tvMascotas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvListaMascotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aún no tienes mascotas registradas."
                android:textSize="14sp"
                android:textColor="#334155" />
        </LinearLayout>

        <!-- Botón registrar mascota -->
        <Button
            android:id="@+id/btnNuevaMascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Registrar nueva mascota"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/layoutMascotas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botón ver mascotas -->
        <Button
            android:id="@+id/btnVerMascotas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ver mis mascotas"
            android:textAllCaps="false"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnNuevaMascota"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ================= SECCIÓN PRODUCTOS ================= -->
        <TextView
            android:id="@+id/tvProductos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Productos"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#0F172A"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/btnVerMascotas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botón productos -->
        <Button
            android:id="@+id/btnProductos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ver productos"
            android:textAllCaps="false"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvProductos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ================= MAPA ================= -->
        <Button
            android:id="@+id/btnBusqueda"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Buscar veterinarias cercanas"
            android:textAllCaps="false"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnProductos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>