<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <!-- Título -->
        <TextView
            android:id="@+id/tvTituloHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Inicio"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/tvSubtitulo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Gestiona tus mascotas y compra productos"
            android:textSize="16sp"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloHome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Sección: Mascotas -->
        <TextView
            android:id="@+id/tvMascotas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Mascotas registradas"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitulo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Contenedor de mascotas -->
        <LinearLayout
            android:id="@+id/layoutMascotas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginTop="10dp"
            android:background="@android:color/darker_gray"
            app:layout_constraintTop_toBottomOf="@id/tvMascotas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvListaMascotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aún no tienes mascotas registradas."
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Registrar mascota -->
        <Button
            android:id="@+id/btnNuevaMascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Registrar nueva mascota"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/layoutMascotas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Ver mascotas -->
        <Button
            android:id="@+id/btnVerMascotas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ver mis mascotas"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnNuevaMascota"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Sección Productos -->
        <TextView
            android:id="@+id/tvProductos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Productos"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/btnVerMascotas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnProductos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ver productos"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvProductos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Notificaciones -->
        <Button
            android:id="@+id/btnNotificaciones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ver notificaciones"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnProductos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Buscar veterinarias -->
        <Button
            android:id="@+id/btnBusqueda"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Buscar veterinarias cercanas"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnNotificaciones"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>