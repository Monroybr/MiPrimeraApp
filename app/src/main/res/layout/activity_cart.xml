<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Título principal -->
    <TextView
        android:id="@+id/tvTituloCart"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Carrito de compras"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Mensaje cuando no hay productos -->
    <TextView
        android:id="@+id/tvVacioCart"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Tu carrito está vacío."
        android:textAlignment="center"
        android:visibility="gone"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloCart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Lista de productos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCart"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvVacioCart"
        app:layout_constraintBottom_toTopOf="@id/tvTotalCart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Total -->
    <TextView
        android:id="@+id/tvTotalCart"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Total: $ 0.00"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnVaciarCart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón vaciar -->
    <Button
        android:id="@+id/btnVaciarCart"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Vaciar carrito"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnFinalizarCompra"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botón finalizar -->
    <Button
        android:id="@+id/btnFinalizarCompra"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Finalizar compra"
        android:layout_marginTop="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>