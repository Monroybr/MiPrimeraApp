<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:padding="16dp">

    <!-- Título principal -->
    <TextView
        android:id="@+id/tvTituloStore"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Tienda para mascotas"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:textAlignment="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtítulo -->
    <TextView
        android:id="@+id/tvSubtituloStore"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Encuentra comida, medicamentos y accesorios"
        android:textSize="14sp"
        android:textColor="#475569"
        android:textAlignment="center"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloStore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Tarjeta del carrito -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardCarritoStore"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="5dp"
        app:cardUseCompatPadding="true"
        app:layout_constraintTop_toBottomOf="@id/tvSubtituloStore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#FFFFFF">

            <TextView
                android:id="@+id/tvCarrito"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Carrito: 0 productos"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#0F172A" />

            <Button
                android:id="@+id/btnVerCarrito"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ver carrito"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:layout_marginTop="10dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Título de filtros -->
    <TextView
        android:id="@+id/tvFiltroTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Filtrar por categoría"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#0F172A"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cardCarritoStore"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Botones de filtro -->
    <LinearLayout
        android:id="@+id/layoutFiltros"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="4"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvFiltroTitulo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnFiltroTodos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Todos"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnFiltroComida"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Comida"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnFiltroMedicamentos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Medicinas"
            android:textAllCaps="false"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnFiltroAccesorios"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Accesorios"
            android:textAllCaps="false"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Lista de productos -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvProductos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/layoutFiltros"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>