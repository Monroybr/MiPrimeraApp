<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvTituloHistorial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Agregar historial clínico"
            android:textStyle="bold"
            android:textSize="22sp"
            android:textAlignment="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvMascotaHist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Selecciona la mascota"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloHistorial"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Spinner
            android:id="@+id/spMascotasHist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvMascotaHist"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etFechaRegistroHist"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Fecha del registro (dd/mm/aaaa)"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/spMascotasHist"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etEnfermedades"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Enfermedades (separa por comas)"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etFechaRegistroHist"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etProcedimientos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Procedimientos realizados"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etEnfermedades"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etMedicacion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Medicación aplicada (dosis, frecuencia, etc.)"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etProcedimientos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnGuardarHistorial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Guardar historial"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etMedicacion"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvMensajeHistorial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textAlignment="center"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnGuardarHistorial"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>