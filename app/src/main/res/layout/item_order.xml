<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvNumeroPedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pedido #1001"
            android:textStyle="bold"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvFechaPedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvClientePedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cliente"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvMetodoPagoPedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Método de pago"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvTotalPedido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Total"
            android:textStyle="bold"
            android:layout_marginTop="6dp" />

        <TextView
            android:id="@+id/tvDetallePedidoItem"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detalle del pedido"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>