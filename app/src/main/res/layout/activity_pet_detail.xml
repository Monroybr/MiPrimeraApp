<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardFotoMascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:gravity="center"
                android:background="#FFFFFF">

                <ImageView
                    android:id="@+id/imgMascotaDetalle"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:src="@mipmap/ic_launcher"
                    android:scaleType="centerCrop"
                    android:background="#E2E8F0"
                    android:contentDescription="Foto de la mascota" />

                <TextView
                    android:id="@+id/tvNombreDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nombre"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#0F172A"
                    android:textAlignment="center"
                    android:layout_marginTop="14dp" />

                <TextView
                    android:id="@+id/tvInfoBasicaDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Raza • Fecha • Edad"
                    android:textSize="14sp"
                    android:textColor="#64748B"
                    android:textAlignment="center"
                    android:layout_marginTop="6dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvSeccionDatos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Datos generales"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/cardFotoMascota"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardDatosMascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="5dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintTop_toBottomOf="@id/tvSeccionDatos"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvCaracteristicasDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Características: -"
                    android:textColor="#334155"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvSexoDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sexo: -"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvPesoDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Peso: -"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvColorDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Color: -"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvAlergiasDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Alergias: -"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvObservacionesDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Observaciones: -"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvSeccionSalud"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Salud de la mascota"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/cardDatosMascota"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardSaludMascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="5dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintTop_toBottomOf="@id/tvSeccionSalud"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="#FFFFFF">

                <TextView
                    android:id="@+id/tvVacunasDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Vacunas registradas: -"
                    android:textColor="#334155"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvHistorialDetalle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Historial médico: -"
                    android:textColor="#334155"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/btnAgregarVacuna"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💉 Agregar vacunación"
                    android:textAllCaps="false"
                    android:layout_marginTop="14dp" />

                <Button
                    android:id="@+id/btnCarnetVacunas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📋 Carnet de vacunación"
                    android:textAllCaps="false"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/btnAgregarHistorial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🩺 Agregar historial clínico"
                    android:textAllCaps="false"
                    android:layout_marginTop="8dp" />

                <Button
                    android:id="@+id/btnVerHistorial"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📄 Ver historial clínico"
                    android:textAllCaps="false"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvSeccionCitas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Citas veterinarias"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/cardSaludMascota"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardCitasMascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="5dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintTop_toBottomOf="@id/tvSeccionCitas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="#FFFFFF">

                <Button
                    android:id="@+id/btnAgendarCita"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📅 Agendar cita veterinaria"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btnVerCitas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="👀 Ver citas veterinarias"
                    android:textAllCaps="false"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvSeccionAcciones"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Acciones"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/cardCitasMascota"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardAccionesMascota"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="5dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintTop_toBottomOf="@id/tvSeccionAcciones"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp"
                android:background="#FFFFFF">

                <Button
                    android:id="@+id/btnEditarMascota"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✏️ Editar mascota"
                    android:textAllCaps="false"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnCompartirInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📄 Compartir información en PDF"
                    android:textAllCaps="false"
                    android:layout_marginTop="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>