<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="18dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Aquí muestro la foto de la mascota -->
        <ImageView
            android:id="@+id/imgMascotaDetalle"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvNombreDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Nombre"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/imgMascotaDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvInfoBasicaDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Raza • Fecha • Edad"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvNombreDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvCaracteristicasDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Características: -"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/tvInfoBasicaDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvSexoDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Sexo: -"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvCaracteristicasDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvPesoDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Peso: -"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvSexoDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvColorDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Color: -"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvPesoDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvAlergiasDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Alergias: -"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvColorDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvObservacionesDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Observaciones: -"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvAlergiasDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvVacunasDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Vacunas registradas: -"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvObservacionesDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvHistorialDetalle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Historial médico: -"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tvVacunasDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnAgregarVacuna"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Agregar vacunación"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvHistorialDetalle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnCarnetVacunas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Carnet de vacunación"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnAgregarVacuna"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnAgregarHistorial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Agregar historial clínico"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnCarnetVacunas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnVerHistorial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ver historial clínico"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnAgregarHistorial"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnCompartirInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Compartir información en PDF"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnVerHistorial"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>