<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvNombreCart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Producto"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCategoriaCart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Categoría"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvPrecioCart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Precio unitario"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvCantidadCart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cantidad: 1"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/tvSubtotalCart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Subtotal: $0"
            android:textStyle="bold"
            android:layout_marginTop="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnDisminuir"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-" />

            <Button
                android:id="@+id/btnAumentar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="+" />

            <Button
                android:id="@+id/btnEliminar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:layout_marginStart="8dp"
                android:text="Eliminar" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>