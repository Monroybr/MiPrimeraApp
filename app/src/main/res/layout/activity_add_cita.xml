<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvTituloAddCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Registrar Cita Veterinaria"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textAlignment="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Spinner
            android:id="@+id/spMascotasCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloAddCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etFechaCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Fecha de la cita (dd/mm/aaaa)"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/spMascotasCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etHoraCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Hora (ej: 14:30)"
            android:inputType="time"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/etFechaCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etVeterinariaCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Veterinaria o clínica"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/etHoraCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/etMotivoCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Motivo de la cita"
            android:minLines="3"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/etVeterinariaCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnGuardarCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Guardar cita"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etMotivoCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvMensajeCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textAlignment="center"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnGuardarCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>