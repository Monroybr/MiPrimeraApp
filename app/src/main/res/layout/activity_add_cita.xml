<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tvTituloCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Agendar cita veterinaria"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textAlignment="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvNombreMascotaCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Mascota"
            android:textStyle="bold"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/tvTituloCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etFechaCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Fecha de la cita"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginTop="14dp"
            app:layout_constraintTop_toBottomOf="@id/tvNombreMascotaCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etHoraCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Hora de la cita"
            android:focusable="false"
            android:clickable="true"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etFechaCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etVeterinaria"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Veterinaria o clínica"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etHoraCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/etMotivoCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Motivo de la cita"
            android:minLines="3"
            android:gravity="top"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/etVeterinaria"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <Button
            android:id="@+id/btnGuardarCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Guardar cita"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etMotivoCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvMensajeCita"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textAlignment="center"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/btnGuardarCita"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>